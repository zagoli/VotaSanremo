{
  "name": "Phoenix",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",

  "forwardPorts": [4000, 5432],

  "postCreateCommand": "mix setup",

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "ElixirLS.elixir-ls",
        "dbaeumer.vscode-eslint",
        "github.copilot",
        "github.copilot-chat",
        "JakeBecker.elixir-ls"
      ]
    }
  }
}
