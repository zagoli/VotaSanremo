<!DOCTYPE html>
<html lang={@locale |> String.replace("_", "-")} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <script>
      (function() {
        var theme = localStorage.getItem("theme") || "light";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title>
      {assigns[:page_title] || "VotaSanremo"}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>

  <body class="bg-base-100 antialiased min-h-screen">
    <!-- DaisyUI Drawer for mobile/side navigation -->
    <div class="drawer">
      <input id="nav-drawer" type="checkbox" class="drawer-toggle" />

      <div class="drawer-content flex flex-col">
        <!-- Navbar — branded navy -->
        <div class="navbar navbar-brand sticky top-0 z-30 shadow-md">
          <div class="flex-none">
            <label
              for="nav-drawer"
              class="btn btn-ghost btn-circle"
              aria-label={dgettext("default", "Open menu")}
            >
              <.icon name="hero-bars-3" class="size-6" />
            </label>
          </div>

          <div class="flex-1">
            <.link
              navigate="/"
              class="link text-xl font-bold tracking-tight flex items-center gap-2 ml-2 no-underline hover:no-underline"
            >
              <.icon name="hero-star-solid" class="size-5 text-secondary" /> VotaSanremo
            </.link>
          </div>
          
<!-- Desktop quick links -->
          <div class="flex-none hidden md:flex items-center gap-1">
            <.link :if={@current_user} navigate={~p"/vote"} class="btn btn-ghost btn-sm">
              {dgettext("default", "Vote")}
            </.link>
            <.link navigate={~p"/leaderboard"} class="btn btn-ghost btn-sm">
              {dgettext("default", "Leaderboard")}
            </.link>
            <.link navigate={~p"/juries"} class="btn btn-ghost btn-sm">
              {dgettext("default", "Juries")}
            </.link>
          </div>
          
<!-- Language switcher & theme toggle -->
          <div class="flex-none flex items-center gap-1 ml-2">
            <div class="flex items-center gap-1">
              <.link href={~p"/?lang=en"} title="English" class="btn btn-ghost btn-xs px-1">
                <Flagpack.usa class="w-5 h-4" />
              </.link>
              <.link href={~p"/?lang=it"} title="Italiano" class="btn btn-ghost btn-xs px-1">
                <Flagpack.ita class="w-5 h-4" />
              </.link>
            </div>
            
<!-- Theme toggle (light/dark) -->
            <label
              class="swap swap-rotate btn btn-ghost btn-circle"
              title={dgettext("default", "Toggle theme")}
            >
              <input
                type="checkbox"
                class="theme-controller"
                value="dark"
                aria-label={dgettext("default", "Toggle dark mode")}
              />
              <!-- sun icon (shown in light mode) -->
              <.icon name="hero-sun" class="swap-off size-5" />
              <!-- moon icon (shown in dark mode) -->
              <.icon name="hero-moon" class="swap-on size-5" />
            </label>
          </div>
        </div>
        
<!-- Page content -->
        {@inner_content}
      </div>
      
<!-- Drawer sidebar -->
      <div class="drawer-side z-40">
        <label for="nav-drawer" aria-label={dgettext("default", "Close menu")} class="drawer-overlay"></label>

        <aside class="bg-base-200 min-h-full w-72 flex flex-col">
          <!-- Sidebar header — branded navy -->
          <div class="sidebar-brand-header p-4 flex items-center justify-between">
            <span class="font-bold text-lg tracking-tight flex items-center gap-2">
              <.icon name="hero-star-solid" class="size-5 text-secondary" /> VotaSanremo
            </span>
            <label for="nav-drawer" class="btn btn-ghost btn-circle btn-sm">
              <.icon name="hero-x-mark" class="size-5" />
            </label>
          </div>

          <ul class="menu w-full flex-1 gap-1 p-3">
            <li :if={@current_user}>
              <.link href={~p"/vote"}>
                <.icon name="hero-star" class="size-4" />
                {dgettext("default", "Vote")}
              </.link>
            </li>

            <li>
              <.link href={~p"/leaderboard"}>
                <.icon name="hero-chart-bar" class="size-4" />
                {dgettext("default", "Leaderboard")}
              </.link>
            </li>

            <li>
              <.link href={~p"/juries"}>
                <.icon name="hero-user-group" class="size-4" />
                {dgettext("default", "Juries")}
              </.link>
            </li>

            <%= if @current_user do %>
              <li>
                <.link href={~p"/search/users"}>
                  <.icon name="hero-magnifying-glass" class="size-4" />
                  {dgettext("default", "Search users")}
                </.link>
              </li>

              <li>
                <.link href={~p"/juries/my_invites"}>
                  <.icon name="hero-envelope" class="size-4" />
                  {dgettext("default", "My invites")}
                </.link>
              </li>

              <li>
                <.link href={~p"/users/settings"}>
                  <.icon name="hero-cog-6-tooth" class="size-4" />
                  {dgettext("default", "Settings")}
                </.link>
              </li>

              <li>
                <.link href={~p"/users/log_out"} method="delete">
                  <.icon name="hero-arrow-right-on-rectangle" class="size-4" />
                  {dgettext("default", "Log out")}
                </.link>
              </li>

              <%= if @current_user.user_type === :admin do %>
                <div class="divider my-2 text-xs font-semibold uppercase tracking-wider opacity-60">
                  {dgettext("default", "Admin")}
                </div>

                <li>
                  <.link href={~p"/admin/users"}>
                    <.icon name="hero-users" class="size-4" />
                    {dgettext("default", "Manage users")}
                  </.link>
                </li>

                <li>
                  <.link href={~p"/admin/editions"}>
                    <.icon name="hero-calendar-days" class="size-4" />
                    {dgettext("default", "Manage editions")}
                  </.link>
                </li>

                <li>
                  <.link href={~p"/admin/performers"}>
                    <.icon name="hero-musical-note" class="size-4" />
                    {dgettext("default", "Manage performers")}
                  </.link>
                </li>

                <li>
                  <.link href={~p"/admin/performance_types"}>
                    <.icon name="hero-tag" class="size-4" />
                    {dgettext("default", "Manage performance types")}
                  </.link>
                </li>
              <% end %>
            <% else %>
              <li>
                <.link href={~p"/users/register"}>
                  <.icon name="hero-user-plus" class="size-4" />
                  {dgettext("default", "Register")}
                </.link>
              </li>

              <li>
                <.link href={~p"/users/log_in"}>
                  <.icon name="hero-arrow-left-on-rectangle" class="size-4" />
                  {dgettext("default", "Log in")}
                </.link>
              </li>
            <% end %>
          </ul>
        </aside>
      </div>
    </div>
  </body>
</html>
